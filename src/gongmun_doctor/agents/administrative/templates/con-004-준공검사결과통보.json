  "variables": [
    {"key": "수신기관", "label": "수신 기관명(시공사)", "example": "(주)○○건설 대표이사"},
    {"key": "관련문서", "label": "관련 준공 요청 문서번호", "example": "도시건설과-2890(2026.10.26.)"},
