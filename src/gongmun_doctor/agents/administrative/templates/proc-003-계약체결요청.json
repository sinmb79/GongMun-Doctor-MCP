  "triggers": ["계약 체결", "계약 요청", "계약서 작성", "계약 締結"],
  "variables": [
    {"key": "수신기관", "label": "수신 기관명", "example": "○○시 계약담당관"},
    {"key": "제목", "label": "공문 제목", "example": "○○도로 확포장 공사 계약 체결 요청"},
    {"key": "공사명", "label": "공사(용역) 명칭", "example": "○○도로 확포장 공사"},
    {"key": "계약상대자", "label": "계약 상대자", "example": "(주)○○건설"},
    {"key": "계약금액", "label": "계약 금액", "example": "금 사억오천만원(450,000,000원)"},
    {"key": "계약기간", "label": "계약 기간", "example": "계약일로부터 210일"},
