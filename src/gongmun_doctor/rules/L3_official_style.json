  "rules": [
    {
      "id": "OS-001",
      "type": "regex_replace",
      "pattern": "관련하여,",
      "replace": "관련하여",
      "desc": "공문서에서 접속 표현 뒤 쉼표 생략",
      "source": "공문서 작성 요령"
    },
    {
