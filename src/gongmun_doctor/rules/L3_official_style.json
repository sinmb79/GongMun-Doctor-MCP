      "source": "공문서 작성 요령"
    },
    {
      "id": "OS-003",
      "type": "regex_replace",
      "pattern": "과 -(\\d)",
      "replace": "과-\\1",
      "desc": "문서번호에서 부서명과 하이픈 사이 공백 제거",
      "source": "행정업무운영편람 제7조"
    },
    {
      "id": "OS-004",
      "type": "regex_replace",
      "pattern": "(\\d{4})\\.(\\d{2})\\.(\\d{2})\\.?\\s*~\\s*(\\d{4})\\.(\\d{2})\\.(\\d{2})\\.?",
      "replace": "\\1. \\2. \\3. ~ \\4. \\5. \\6.",
